{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "functions": {
          "api/index.py": {
            "runtime": "python3.12@latest",
            "maxDuration": 30
          }
        }
      }
    }
  ],
  "routes": [
    { "src": "/health", "dest": "api/index.py" },
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
