# =============================================================================
# OpenCouncil — Environment Configuration
# =============================================================================
#
# REQUIRED: DEEPSEEK_API_KEY must be set for summarization.
#
# DEEPSEEK_API_KEY — for text-based summarization (works with OCR-extracted text)
#
# Scanned document images (TIFF) are handled by Tesseract OCR (free, open-source)
# which extracts text from images before passing to DeepSeek for summarization.
# No paid API keys needed beyond DeepSeek!
# =============================================================================

# --- DeepSeek API Key (text summarization) ---
#
# OPTION A: Plaintext (local dev only — DO NOT commit this to GitHub)
#   DEEPSEEK_API_KEY=sk-your-deepseek-key-here
#
# OPTION B: Encrypted (GitHub-safe — set these in Vercel/HF Spaces)
#   1. Generate an encryption key:
#      python -c "from crypto_utils import generate_key; print(generate_key())"
#   2. Encrypt your DeepSeek API key:
#      python -c "from crypto_utils import encrypt_api_key; print(encrypt_api_key('sk-your-key'))"
#   3. Set these as environment variables in your deployment platform:
#      ENCRYPTION_KEY=<the generated key>
#      ENCRYPTED_DEEPSEEK_KEY=<the encrypted key>
#
# The app checks DEEPSEEK_API_KEY first, then falls back to ENCRYPTED_DEEPSEEK_KEY.

# Plaintext API key (local dev only — add .env to .gitignore!)
DEEPSEEK_API_KEY=

# Encrypted API key (GitHub-safe deployment)
ENCRYPTED_DEEPSEEK_KEY=
ENCRYPTION_KEY=

# Supabase PostgreSQL connection string (for HF Spaces deployment)
# Get this from your Supabase project dashboard → Settings → Database
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# =============================================================================
# Supabase Auth Configuration (for volunteer verification system)
# =============================================================================
#
# These are required for the auth and verification endpoints.
# Get these from your Supabase project dashboard → Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL — your Supabase project URL (e.g., https://xxxxx.supabase.co)
# NEXT_PUBLIC_SUPABASE_ANON_KEY — the public anon key (safe for client-side)
# SUPABASE_SERVICE_ROLE_KEY — the service role key (server-side only, keep secret!)
# SUPABASE_STORAGE_BUCKET — the storage bucket name for OpenCouncil cards

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=civic-cards

# =============================================================================
# Meta Graph API (for social media posting)
# =============================================================================
#
# These are required for the social media pipeline (Phase 5).
# Get these from your Meta Developer dashboard → Facebook App → Graph API.
#
# META_PAGE_ID — your Facebook Page ID (numeric)
# META_PAGE_ACCESS_TOKEN — a Page Access Token with publish_photo permission
# META_INSTAGRAM_ACCOUNT_ID — your Instagram Business Account ID (numeric)
#
# The Instagram account must be a Business account connected to the Facebook Page.
# Generate the Page Access Token at:
#   https://developers.facebook.com/tools/explorer/
#   → Select your app → Get Page Access Token → Select your page

META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_INSTAGRAM_ACCOUNT_ID=
